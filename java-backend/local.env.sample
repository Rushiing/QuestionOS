# 复制为同目录下的 `.env`（已被 .gitignore，勿提交密钥）
# 启动：在 java-backend 目录执行 `set -a && source .env && set +a && mvn spring-boot:run`
# 或使用仓库根目录 `scripts/run-backend-local.sh`

QUESTIONOS_SANDBOX_TOKEN=sk-sandbox-dev
# 默认 false：会话标题仅首问截断，不并行打 LLM
# QUESTIONOS_SESSION_TITLE_FROM_LLM=true
QUESTIONOS_LLM_ENDPOINT=https://coding.dashscope.aliyuncs.com/v1
QUESTIONOS_LLM_API_KEY=<your-dashscope-key>
QUESTIONOS_LLM_MODEL=glm-5
# 可选，默认 240（秒）；线上仍超时再调到 300～420
# QUESTIONOS_LLM_TIMEOUT_SECONDS=240
# 可选，默认 4096；若网关报参数错误可改为 0 关闭 max_tokens 字段
# QUESTIONOS_LLM_MAX_TOKENS=4096
# 百炼/DashScope：请求体 extra_body.enable_thinking，默认 false（关闭思维链）
# QUESTIONOS_LLM_EXTRA_BODY_ENABLE_THINKING=false
